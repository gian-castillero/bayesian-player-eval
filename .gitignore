# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python

# ── Virtual environments ───────────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/

# ── Secrets ────────────────────────────────────────────────────────────────────
.env
.env.*
secrets.toml

# ── Jupyter ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Streamlit ──────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Data (licensed — never commit raw or processed exports) ────────────────────
# Exclude contents but not the directories themselves (so .gitkeep is tracked)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# ── Model outputs (large files — reproducible from the pipeline) ───────────────
outputs/traces/*
!outputs/traces/.gitkeep
outputs/rankings/*
!outputs/rankings/.gitkeep

# ── macOS ──────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDEs ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Claude Code session data ───────────────────────────────────────────────────
.claude/

# ── Type checking / linting caches ────────────────────────────────────────────
.mypy_cache/
.ruff_cache/
.pytest_cache/
